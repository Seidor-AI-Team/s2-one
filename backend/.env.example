# ── S2-ONE Backend Environment Variables ──

# OpenAI — Required for AI narrative generation
OPENAI_API_KEY=sk-...

# Security — Bearer tokens for API authentication
# If both are empty, auth is disabled (dev mode)
API_TOKEN=s2one-hackathon-2026
ADMIN_TOKEN=s2one-admin-2026

# CORS — Comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5176
